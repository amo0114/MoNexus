{
  "name": "monexus",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20 <21",
    "npm": ">=10 <11"
  },
  "scripts": {
    "check:runtime": "node scripts/check-runtime.mjs",
    "verify:local": "bash scripts/verify-local.sh",
    "verify:local:no-e2e": "RUN_E2E=false bash scripts/verify-local.sh",
    "prod:env": "bash scripts/check-prod-env.sh",
    "prod:env:staging": "bash scripts/check-prod-env.sh --mode staging --env-file .env.staging.local",
    "prod:env:staging-template": "bash scripts/check-prod-env.sh --mode staging --env-file .env.staging.example --allow-placeholders",
    "prod:config": "bash scripts/prod-compose-config.sh",
    "prod:build": "docker compose --project-name ${COMPOSE_PROJECT_NAME:-monexus-prod} --env-file ${ENV_FILE:-.env} -f docker-compose.prod.yml build",
    "prod:up": "docker compose --project-name ${COMPOSE_PROJECT_NAME:-monexus-prod} --env-file ${ENV_FILE:-.env} -f docker-compose.prod.yml up -d",
    "prod:ps": "docker compose --project-name ${COMPOSE_PROJECT_NAME:-monexus-prod} --env-file ${ENV_FILE:-.env} -f docker-compose.prod.yml ps",
    "prod:smoke": "bash scripts/prod-smoke.sh",
    "prod:gate": "npm run prod:env && npm run prod:config && npm run prod:build && npm run prod:up && npm run prod:ps && REQUIRE_METRICS_TOKEN=true npm run prod:smoke",
    "backup:restore-check": "bash scripts/restore-check.sh",
    "predev": "npm run check:runtime",
    "dev": "vite",
    "prebuild": "npm run check:runtime",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/react": "^10.53.0",
    "axios": "^1.7.0",
    "dompurify": "^3.4.1",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "web-vitals": "^5.2.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "~5.6.2",
    "vite": "^6.0.0"
  }
}
