# =============================================================================
# MoNexus — staging environment variables
#
# Copy to `.env.staging.local` or `.env` and fill in real values before a
# production-like compose rehearsal. Never commit filled env files.
# Validate with:
#   npm run prod:env:staging
# =============================================================================

# --- Database ---
POSTGRES_USER=monexus_staging
POSTGRES_PASSWORD=<set-strong-random-password>
POSTGRES_DB=monexus_staging

# --- Server ---
JWT_SECRET=<set-generated-csprng-value-at-least-32-chars>
FRONTEND_ORIGIN=https://staging.example.com
COOKIE_SECURE=true
APP_BASE_URL=https://staging.example.com
USER_STATUS_CACHE_TTL_SEC=60

# --- Object storage ---
# Use an isolated staging bucket. If using the bundled MinIO for rehearsal,
# run compose with `COMPOSE_PROFILES=selfhost-storage` and keep
# STORAGE_ENDPOINT pointed at http://minio:9000.
STORAGE_ENDPOINT=https://s3-staging.example.com
STORAGE_REGION=us-east-1
STORAGE_BUCKET=monexus-staging-uploads
STORAGE_ACCESS_KEY=<set-staging-storage-access-key>
STORAGE_SECRET_KEY=<set-staging-storage-secret-key>
STORAGE_PUBLIC_URL_BASE=https://cdn-staging.example.com/monexus-staging-uploads
STORAGE_FORCE_PATH_STYLE=true

# --- Transactional email / SMTP ---
SMTP_HOST=smtp-staging.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<set-staging-smtp-user>
SMTP_PASS=<set-staging-smtp-password-or-token>
SMTP_FROM=noreply-staging@example.com

# --- Observability ---
SENTRY_DSN=https://<key>@<host>/<project>
VITE_SENTRY_DSN=https://<key>@<host>/<project>
LOG_LEVEL=info
METRICS_TOKEN=<set-random-bearer-token>

# --- Backup / restore rehearsal ---
# BACKUP_DATABASE_URL should point at the source DB to dump. For staging
# rehearsals this can be the staging DB; for production scheduled backups,
# use a production read-only role in GitHub secrets.
BACKUP_DATABASE_URL=postgresql://monexus_backup:<password>@staging-db.example.com:5432/monexus_staging?sslmode=require
RESTORE_TARGET_URL=postgresql://monexus_restore:<password>@staging-db.example.com:5432/monexus_restore?sslmode=require

# --- Frontend container ---
WEB_PORT=18081
MAILPIT_WEB_PORT=18082
