generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["windows", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  password      String
  role          String    @default("user") // user | admin | merchant
  status        String    @default("正常")
  inviteCode    String    @unique @default(uuid())
  nickname      String? // 1-20 字，个人中心可设；评价展示名回退邮箱打码
  emailVerified DateTime?
  createdAt     DateTime  @default(now())

  pointAccount            PointAccount?
  orders                  Order[]
  pointLogs               PointLog[]
  checkins                CheckinRecord[]
  refreshTokens           RefreshToken[]
  orderStatusEvents       OrderStatusEvent[]
  invitedBy               InviteRelation[]         @relation("invitee")
  invites                 InviteRelation[]         @relation("inviter")
  adminLogs               AdminLog[]
  updatedSystemConfigs    SystemConfig[]           @relation("SystemConfigUpdatedBy")
  approvedMerchants       Merchant[]               @relation("MerchantApprovedBy")
  merchant                Merchant?
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  reviews                 Review[]
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  tokenHash String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model EmailVerificationToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  tokenHash String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Merchant {
  id             Int       @id @default(autoincrement())
  userId         Int       @unique
  name           String
  description    String?
  status         String    @default("pending") // pending | active | suspended | rejected
  commissionRate Decimal   @default(0.10) @db.Decimal(5, 4)
  contactEmail   String?
  contactPhone   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  approvedAt     DateTime?
  approvedBy     Int?

  user           User         @relation(fields: [userId], references: [id])
  approvedByUser User?        @relation("MerchantApprovedBy", fields: [approvedBy], references: [id])
  products       Product[]
  orders         Order[]
  settlements    Settlement[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  tokenHash String
  revoked   Boolean  @default(false)
  expiresAt DateTime
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model PointAccount {
  id      Int @id @default(autoincrement())
  userId  Int @unique
  balance Int @default(0)

  user User @relation(fields: [userId], references: [id])
}

model PointLog {
  id           Int      @id @default(autoincrement())
  userId       Int
  type         String // in | out
  amount       Int
  balanceAfter Int
  reason       String?
  orderId      Int?
  createdAt    DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])
}

model Product {
  id               Int      @id @default(autoincrement())
  name             String
  description      String?
  richDescription  String?
  type             String // 网络节点 / 共享账号 / 充值卡密 / 邀请码
  icon             String   @default("package")
  imageUrl         String?
  images           String[] @default([])
  price            Int
  originalPrice    Int?
  stock            Int      @default(0)
  sales            Int      @default(0)
  ratingAvg        Decimal  @default(0) @db.Decimal(2, 1) // ratingCount=0 时无意义，前端显示「暂无评分」
  ratingCount      Int      @default(0)
  isHot            Boolean  @default(false)
  status           String   @default("active") // active | inactive
  deliveryMode     String   @default("instant_inventory") // instant_inventory | instant_fixed | manual_service
  stockMode        String   @default("limited") // limited | unlimited（instant_inventory 强制 limited）
  fixedContent     String? // instant_fixed 专用：固定交付内容（付费内容，禁止公开序列化）
  fixedContentType String   @default("text") // text | url
  merchantId       Int?
  createdAt        DateTime @default(now())

  merchant      Merchant?       @relation(fields: [merchantId], references: [id])
  reviews       Review[]
  orders        Order[]
  inventory     InventoryItem[]
  inventoryLogs InventoryLog[]

  @@index([status, isHot, sales, id])
}

model InventoryLog {
  id          Int      @id @default(autoincrement())
  productId   Int
  merchantId  Int?
  actorUserId Int
  action      String // import | void
  delta       Int // 导入为正、作废为负
  reason      String?
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId, createdAt])
}

model Review {
  id            Int       @id @default(autoincrement())
  productId     Int
  userId        Int
  orderId       Int       @unique // 一订单一评的数据库级保证
  rating        Int // 1-5 整数星
  comment       String? // ≤500 字纯文本
  status        String    @default("visible") // visible | removed
  editableUntil DateTime // 创建时快照 createdAt + 7 天
  editedAt      DateTime? // 非空 = 已用掉唯一一次修改机会
  createdAt     DateTime  @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id])

  @@index([productId, status, createdAt])
}

model InventoryItem {
  id           Int       @id @default(autoincrement())
  productId    Int
  content      String
  status       String    @default("available") // available | sold | void
  orderId      Int?      @unique
  soldToUserId Int?
  soldAt       DateTime?
  createdAt    DateTime  @default(now())

  product Product @relation(fields: [productId], references: [id])
}

model Order {
  id               Int      @id @default(autoincrement())
  userId           Int
  productId        Int
  price            Int
  status           String   @default("pending")
  merchantId       Int?
  commissionRate   Decimal? @db.Decimal(5, 4)
  commissionAmount Int      @default(0)
  createdAt        DateTime @default(now())

  user         User               @relation(fields: [userId], references: [id])
  product      Product            @relation(fields: [productId], references: [id])
  merchant     Merchant?          @relation(fields: [merchantId], references: [id])
  delivery     DeliveryRecord?
  review       Review?
  settlement   Settlement?
  pointLogs    PointLog[]
  statusEvents OrderStatusEvent[]
}

model DeliveryRecord {
  id          Int       @id @default(autoincrement())
  orderId     Int       @unique
  userId      Int
  productId   Int
  content     String?
  contentType String    @default("text") // text | url | file
  status      String    @default("delivered")
  publicNote  String?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

model OrderStatusEvent {
  id           Int      @id @default(autoincrement())
  orderId      Int
  actorUserId  Int?
  actorRole    String
  fromStatus   String?
  toStatus     String
  action       String
  publicNote   String?
  internalNote String?
  createdAt    DateTime @default(now())

  order     Order @relation(fields: [orderId], references: [id])
  actorUser User? @relation(fields: [actorUserId], references: [id])

  @@index([orderId, createdAt])
  @@index([actorUserId])
}

model Settlement {
  id               Int       @id @default(autoincrement())
  merchantId       Int
  orderId          Int       @unique
  orderAmount      Int
  commissionRate   Decimal   @db.Decimal(5, 4)
  commissionAmount Int
  settlementAmount Int
  status           String    @default("pending") // pending | settled
  settledAt        DateTime?
  createdAt        DateTime  @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id])
  order    Order    @relation(fields: [orderId], references: [id])
}

model CheckinRecord {
  id        Int      @id @default(autoincrement())
  userId    Int
  date      String // YYYY-MM-DD
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model InviteRelation {
  id        Int      @id @default(autoincrement())
  inviterId Int
  inviteeId Int      @unique
  createdAt DateTime @default(now())

  inviter User @relation("inviter", fields: [inviterId], references: [id])
  invitee User @relation("invitee", fields: [inviteeId], references: [id])
}

model AdminLog {
  id          Int      @id @default(autoincrement())
  adminUserId Int
  action      String
  targetType  String?
  targetId    Int?
  detail      String?
  createdAt   DateTime @default(now())

  admin User @relation(fields: [adminUserId], references: [id])
}

model SystemConfig {
  key         String   @id @unique
  value       Int
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   Int?

  updatedByUser User? @relation("SystemConfigUpdatedBy", fields: [updatedBy], references: [id])
}
