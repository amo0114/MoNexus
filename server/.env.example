NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://<local-user>:<local-password>@localhost:5432/monexus?schema=public
JWT_SECRET=replace-with-at-least-32-random-characters
FRONTEND_ORIGIN=http://localhost:5173
COOKIE_SECURE=false

# --- Auth performance / status cache (M3-A5) ---
# TTL (seconds) for the in-memory User.status LRU cache that powers
# `requireActiveUser`. 0 disables the cache and every protected request
# hits Prisma — equivalent to pre-M3 behavior. 60 (default) is a sensible
# production value: ban / unban / password-change paths invalidate
# explicitly, so the TTL only bounds how long a status mutation that
# happens *outside* those paths (e.g. raw DB edit) takes to propagate.
USER_STATUS_CACHE_TTL_SEC=60

# --- Object storage (P0-C) ---
# Optional in dev: leave all unset to fall back to an in-memory adapter.
# Required in production (server refuses to boot if NODE_ENV=production
# and any of these four are missing).
#
# Local development with `docker compose up`:
#   STORAGE_ENDPOINT=http://localhost:9000
#   STORAGE_BUCKET=monexus-uploads
#   STORAGE_ACCESS_KEY=minio
#   STORAGE_SECRET_KEY=minio_dev_password
#   STORAGE_PUBLIC_URL_BASE=http://localhost:9000/monexus-uploads
#
# STORAGE_ENDPOINT=
# STORAGE_REGION=us-east-1
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_PUBLIC_URL_BASE=
# STORAGE_FORCE_PATH_STYLE=true

# --- Transactional email / SMTP (M3-A1) ---
# Optional in dev: leave SMTP_HOST unset and the server uses a console
# mailer that logs to stdout (good enough for password-reset / verify
# flows during development). Set SMTP_HOST to opt into real delivery
# via nodemailer.
#
# Local dev recipe (MailHog SMTP catcher with web UI on :8025):
#   docker run --rm -p 1025:1025 -p 8025:8025 mailhog/mailhog
#   SMTP_HOST=localhost
#   SMTP_PORT=1025
#   SMTP_SECURE=false
#   # MailHog accepts unauthenticated submissions — leave USER/PASS unset.
#   SMTP_FROM=noreply@monexus.local
#
# Production examples (provider docs are authoritative):
#   - AWS SES SMTP:  SMTP_HOST=email-smtp.<region>.amazonaws.com SMTP_PORT=587 SMTP_SECURE=false (STARTTLS)
#   - Mailtrap:      SMTP_HOST=sandbox.smtp.mailtrap.io           SMTP_PORT=2525 SMTP_SECURE=false
#   - Gmail SMTP:    SMTP_HOST=smtp.gmail.com                     SMTP_PORT=465 SMTP_SECURE=true
#
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=<set-provider-password-or-token>
# SMTP_FROM=noreply@example.com

# Base URL written into email links (password reset, verify email).
# Falls back to FRONTEND_ORIGIN when unset. Override only when the
# user-facing link host differs from the CORS origin (e.g. behind a
# CDN with a different hostname for transactional links).
# APP_BASE_URL=

# --- Error reporting / Sentry (M2 GA; documented in M3) ---
# Optional. Leave unset in local dev so backend errors don't get sent
# anywhere. In staging / prod, set to your Sentry or self-hosted
# GlitchTip project DSN. Errors flow via `@sentry/node`.
# SENTRY_DSN=https://<key>@<host>/<project>

# --- Logging (M2 GA) ---
# pino log level. One of: fatal | error | warn | info | debug | trace | silent.
# Defaults to "info". Raise to "debug" or "trace" only when chasing
# specific issues — `trace` is very chatty.
# LOG_LEVEL=info

# --- Metrics endpoint protection (M4-A3) ---
# When set, GET /api/metrics requires 'Authorization: Bearer <token>'.
# Strongly recommended in production. Leave unset only when /api/metrics
# is shielded from the public internet (e.g. behind a firewall or
# private VPC). Generate with: openssl rand -hex 32
# METRICS_TOKEN=
