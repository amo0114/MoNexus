# =============================================================================
# MoNexus — production environment variables
#
# Copy to `.env` (at repo root) and fill in real values before running
# `docker compose -f docker-compose.prod.yml up -d`. The `.env` file is in
# .gitignore so secrets never get committed.
# =============================================================================

# --- Database ---
POSTGRES_USER=monexus
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=monexus

# --- Server ---
# JWT secret must be AT LEAST 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-at-least-32-random-characters-from-csprng

# The browser-facing origin of the frontend. Used for CORS.
# Production example: https://app.example.com
FRONTEND_ORIGIN=http://localhost

# Set to "true" once you're serving the frontend over HTTPS so the
# refresh-token cookie carries the Secure flag.
COOKIE_SECURE=true

# --- Object storage (P0-C) ---
# Required in production. The server refuses to boot if any of the
# four core values (ENDPOINT, BUCKET, ACCESS_KEY, SECRET_KEY) is
# missing while NODE_ENV=production.
#
# Self-hosted with the bundled MinIO (run with `--profile selfhost-storage`):
#   STORAGE_ENDPOINT=http://minio:9000
#   STORAGE_BUCKET=monexus-uploads
#   STORAGE_ACCESS_KEY=<choose>  # also becomes MinIO root user
#   STORAGE_SECRET_KEY=<choose>  # also becomes MinIO root password
#   STORAGE_PUBLIC_URL_BASE=https://cdn.example.com/monexus-uploads
#
# External S3 / R2 / OSS: point STORAGE_ENDPOINT at the provider URL
# and leave the `selfhost-storage` profile off.
STORAGE_ENDPOINT=http://minio:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=monexus-uploads
STORAGE_ACCESS_KEY=replace-me
STORAGE_SECRET_KEY=replace-me-too
STORAGE_PUBLIC_URL_BASE=
STORAGE_FORCE_PATH_STYLE=true
