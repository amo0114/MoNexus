# =============================================================================
# MoNexus — production environment variables
#
# Copy to `.env` (at repo root) and fill in real values before running
# `docker compose -f docker-compose.prod.yml up -d`. The `.env` file is in
# .gitignore so secrets never get committed.
# =============================================================================

# --- Database ---
POSTGRES_USER=monexus
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=monexus

# --- Server ---
# JWT secret must be AT LEAST 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-at-least-32-random-characters-from-csprng

# The browser-facing origin of the frontend. Used for CORS.
# Production example: https://app.example.com
FRONTEND_ORIGIN=http://localhost

# Set to "true" once you're serving the frontend over HTTPS so the
# refresh-token cookie carries the Secure flag.
COOKIE_SECURE=true

# Base URL written into transactional email links (password reset,
# verify email). Falls back to FRONTEND_ORIGIN when unset. Override
# only when the link host differs from the CORS origin (e.g. behind
# a CDN with a separate hostname for outbound links).
# APP_BASE_URL=https://app.example.com

# --- Auth performance / status cache (M3-A5) ---
# TTL (seconds) for the in-memory User.status LRU cache. 0 disables
# the cache (every protected request hits the DB — pre-M3 behavior).
# 60 is the production default; ban / unban / password-change paths
# invalidate explicitly, so TTL only bounds out-of-band mutations.
USER_STATUS_CACHE_TTL_SEC=60

# --- Object storage (P0-C) ---
# Required in production. The server refuses to boot if any of the
# four core values (ENDPOINT, BUCKET, ACCESS_KEY, SECRET_KEY) is
# missing while NODE_ENV=production.
#
# Self-hosted with the bundled MinIO (run with `--profile selfhost-storage`):
#   STORAGE_ENDPOINT=http://minio:9000
#   STORAGE_BUCKET=monexus-uploads
#   STORAGE_ACCESS_KEY=<choose>  # also becomes MinIO root user
#   STORAGE_SECRET_KEY=<choose>  # also becomes MinIO root password
#   STORAGE_PUBLIC_URL_BASE=https://cdn.example.com/monexus-uploads
#
# External S3 / R2 / OSS: point STORAGE_ENDPOINT at the provider URL
# and leave the `selfhost-storage` profile off.
STORAGE_ENDPOINT=http://minio:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=monexus-uploads
STORAGE_ACCESS_KEY=replace-me
STORAGE_SECRET_KEY=replace-me-too
STORAGE_PUBLIC_URL_BASE=
STORAGE_FORCE_PATH_STYLE=true

# --- Transactional email / SMTP (M3-A1) ---
# When SMTP_HOST is unset the server falls back to a console mailer
# (no real delivery). In production, SMTP_HOST must point to a real
# SMTP relay so password-reset / verify-email actually arrive.
#
# Provider snippets (consult provider docs for current values):
#   AWS SES SMTP: SMTP_HOST=email-smtp.<region>.amazonaws.com  SMTP_PORT=587 SMTP_SECURE=false
#   Mailtrap:     SMTP_HOST=sandbox.smtp.mailtrap.io            SMTP_PORT=2525 SMTP_SECURE=false
#   Gmail SMTP:   SMTP_HOST=smtp.gmail.com                      SMTP_PORT=465 SMTP_SECURE=true
#
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# --- Error reporting (M2 GA; documented in M3) ---
# Backend Sentry / GlitchTip DSN. Errors are forwarded via @sentry/node.
# Leave unset in dev / staging if you don't want to ship events there.
# SENTRY_DSN=https://<key>@<host>/<project>

# Frontend Sentry / GlitchTip DSN, baked in at Vite build time. Errors
# are forwarded via @sentry/react from the React error boundary plus
# the global handler in src/main.tsx. Leave unset in dev to silence.
# VITE_SENTRY_DSN=https://<key>@<host>/<project>

# --- Logging (M2 GA) ---
# pino log level: fatal | error | warn | info | debug | trace | silent.
# Defaults to "info". Raise temporarily when chasing an incident.
# LOG_LEVEL=info
